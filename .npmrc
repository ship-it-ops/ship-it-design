auto-install-peers=true
strict-peer-dependencies=false
shared-workspace-lockfile=true
link-workspace-packages=true
prefer-workspace-packages=true

# Storybook 10's MDX compiler emits deep imports into `@storybook/addon-docs/dist/*`
# that pnpm's strict isolation hides; hoist storybook packages to the workspace
# root (npm-style flat layout) so Vite/Rollup can resolve them.
node-linker=hoisted
public-hoist-pattern[]=*storybook*
public-hoist-pattern[]=@storybook/*
