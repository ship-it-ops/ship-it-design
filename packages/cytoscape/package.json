{
  "name": "@ship-it-ui/cytoscape",
  "version": "0.0.1",
  "description": "Cytoscape adapter for the Ship-It design system. Token-driven stylesheet, theme-aware re-resolver hook, and a `<GraphCanvas>` wrapper that owns the data-theme ↔ stylesheet ↔ inspector dance.",
  "license": "MIT",
  "homepage": "https://ship-it-ops.github.io/ship-it-design/",
  "bugs": {
    "url": "https://github.com/ship-it-ops/ship-it-design/issues"
  },
  "author": "Ship-It Ops",
  "keywords": [
    "design-system",
    "cytoscape",
    "graph",
    "knowledge-graph",
    "shipit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ship-it-ops/ship-it-design.git",
    "directory": "packages/cytoscape"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "@ship-it-ui/shipit": "workspace:*",
    "@ship-it-ui/ui": "workspace:*",
    "cytoscape": "^3.28.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@ship-it-ui/eslint-config": "workspace:*",
    "@ship-it-ui/shipit": "workspace:*",
    "@ship-it-ui/tokens": "workspace:*",
    "@ship-it-ui/tsconfig": "workspace:*",
    "@ship-it-ui/ui": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/cytoscape": "^3.21.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "axe-core": "^4.10.2",
    "cytoscape": "^3.30.0",
    "esbuild-plugin-preserve-directives": "^0.0.11",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3",
    "vitest-axe": "^0.1.0"
  }
}
