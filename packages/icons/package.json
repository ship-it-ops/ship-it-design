{
  "name": "@ship-it-ui/icons",
  "version": "0.0.10",
  "description": "Iconography for the Ship-It design system: glyph-first IconGlyph + SVGR pipeline for SVG icons.",
  "license": "MIT",
  "homepage": "https://ship-it-ops.github.io/ship-it-design/",
  "bugs": {
    "url": "https://github.com/ship-it-ops/ship-it-design/issues"
  },
  "author": "Ship-It Ops",
  "keywords": [
    "design-system",
    "react",
    "icons",
    "svgr",
    "shipit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ship-it-ops/ship-it-design.git",
    "directory": "packages/icons"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsx scripts/build-icon-data.ts && tsx scripts/build.ts && tsup",
    "icons:sync": "tsx scripts/build-icon-data.ts",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist src/components/*.tsx .turbo"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.109",
    "@iconify-json/ph": "^1.2.0",
    "@iconify-json/simple-icons": "^1.2.83",
    "@iconify/utils": "^2.1.30",
    "@ship-it-ui/eslint-config": "workspace:*",
    "@ship-it-ui/tsconfig": "workspace:*",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^24",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/coverage-v8": "^2.1.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  }
}
