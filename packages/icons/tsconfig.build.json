{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": false,
    "incremental": false,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "jsx": "react-jsx"
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", "scripts", "src/test", "**/*.test.ts", "**/*.test.tsx"]
}
