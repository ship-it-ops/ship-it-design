{
  "name": "@ship-it-ui/tokens",
  "version": "0.0.10",
  "description": "Design tokens for the Ship-It design system. The single source of truth for color, type, spacing, radius, shadow, motion, breakpoints, and z-index.",
  "license": "MIT",
  "homepage": "https://ship-it-ops.github.io/ship-it-design/",
  "bugs": {
    "url": "https://github.com/ship-it-ops/ship-it-design/issues"
  },
  "author": "Ship-It Ops",
  "keywords": [
    "design-system",
    "design-tokens",
    "css-variables",
    "tailwindcss",
    "shipit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ship-it-ops/ship-it-design.git",
    "directory": "packages/tokens"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "shipit": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "require": "./dist/config.cjs"
    },
    "./styles/tokens.css": "./styles/tokens.css"
  },
  "files": [
    "dist",
    "styles",
    "README.md"
  ],
  "sideEffects": [
    "./styles/tokens.css"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup && tsx scripts/build-css.ts",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist styles/tokens.css .turbo"
  },
  "devDependencies": {
    "@ship-it-ui/eslint-config": "workspace:*",
    "@ship-it-ui/tsconfig": "workspace:*",
    "@types/node": "^24",
    "@vitest/coverage-v8": "^3.2.6",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "jiti": "^2.7.0"
  }
}
