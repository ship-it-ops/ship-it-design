{
  "name": "@ship-it-ui/graph-tokens",
  "version": "0.0.2",
  "description": "Token-resolution helpers for Ship-It graph adapters. Reads `--color-*` CSS variables at runtime and coerces them to sRGB strings that non-DOM renderers (Cytoscape, React Flow) can parse.",
  "license": "MIT",
  "homepage": "https://ship-it-ops.github.io/ship-it-design/",
  "bugs": {
    "url": "https://github.com/ship-it-ops/ship-it-design/issues"
  },
  "author": "Ship-It Ops",
  "keywords": [
    "design-system",
    "design-tokens",
    "graph",
    "shipit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ship-it-ops/ship-it-design.git",
    "directory": "packages/graph-tokens"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@ship-it-ui/eslint-config": "workspace:*",
    "@ship-it-ui/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "jsdom": "^29.1.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  }
}
