{
  "name": "@ship-it-ui/map",
  "version": "0.0.11",
  "description": "Map primitive for the Ship-It design system. Thin React wrapper over MapLibre GL JS with styled markers that consume design-system tokens.",
  "license": "MIT",
  "homepage": "https://ship-it-ops.github.io/ship-it-design/",
  "bugs": {
    "url": "https://github.com/ship-it-ops/ship-it-design/issues"
  },
  "author": "Ship-It Ops",
  "keywords": [
    "design-system",
    "map",
    "maplibre",
    "shipit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ship-it-ops/ship-it-design.git",
    "directory": "packages/map"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "@ship-it-ui/icons": "workspace:*",
    "@ship-it-ui/ui": "workspace:*",
    "maplibre-gl": "^4.0.0 || ^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@ship-it-ui/eslint-config": "workspace:*",
    "@ship-it-ui/icons": "workspace:*",
    "@ship-it-ui/tokens": "workspace:*",
    "@ship-it-ui/tsconfig": "workspace:*",
    "@ship-it-ui/ui": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "axe-core": "^4.10.2",
    "esbuild-plugin-preserve-directives": "^0.0.11",
    "jsdom": "^29.1.1",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3",
    "vitest-axe": "^0.1.0"
  }
}
