{
  "name": "ship-it-design",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Ship-It design system & component library — tokens, icons, and React components consumed by Ship-It front-end apps.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start:docs": "pnpm --filter docs-site dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:force": "turbo run test --force",
    "typecheck": "turbo run typecheck",
    "typecheck:force": "turbo run typecheck --force",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mdx,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mdx,css,yml,yaml}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "changeset:empty": "changeset add --empty",
    "version-packages": "changeset version",
    "release": "turbo run build --filter='./packages/*' && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@ship-it-ui/eslint-config": "workspace:*",
    "@ship-it-ui/tsconfig": "workspace:*",
    "eslint": "^9.13.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "turbo": "^2.9.18",
    "typescript": "^5.6.3",
    "vite": "^6.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,mdx,css,yml,yaml}": "prettier --write"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@>=5.0.0 <5.0.6": "^5.0.6",
      "esbuild@<0.28.1": "^0.28.1",
      "postcss@<8.5.10": "^8.5.10",
      "undici@<7.28.0": "^7.28.0",
      "vite": "^6.4.3",
      "js-yaml@>=4.0.0 <4.2.0": "^4.2.0",
      "js-yaml@<3.15.0": "^3.15.0",
      "@babel/core@<7.29.6": "^7.29.6",
      "@vitest/utils": "3.2.6",
      "@vitest/expect": "3.2.6"
    }
  }
}
