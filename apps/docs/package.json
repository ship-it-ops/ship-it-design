{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "description": "Storybook 8 documentation site for the Ship-It design system.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "build": "storybook build -o storybook-static",
    "lint": "eslint .storybook",
    "test": "storybook build --test -o storybook-static",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf storybook-static .turbo"
  },
  "dependencies": {
    "@ship-it/icons": "workspace:*",
    "@ship-it/shipit": "workspace:*",
    "@ship-it/tokens": "workspace:*",
    "@ship-it/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@ship-it/eslint-config": "workspace:*",
    "@ship-it/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-interactions": "^8.4.0",
    "@storybook/addon-links": "^8.4.0",
    "@storybook/addon-themes": "^8.4.0",
    "@storybook/blocks": "^8.4.0",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@storybook/test": "^8.4.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "storybook": "^8.4.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
