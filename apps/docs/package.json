{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "description": "Storybook 10 documentation site for the Ship-It design system.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "build": "storybook build -o storybook-static",
    "lint": "eslint .storybook",
    "test": "storybook build --test -o storybook-static",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf storybook-static .turbo"
  },
  "dependencies": {
    "@ship-it-ui/icons": "workspace:*",
    "@ship-it-ui/shipit": "workspace:*",
    "@ship-it-ui/tokens": "workspace:*",
    "@ship-it-ui/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@ship-it-ui/eslint-config": "workspace:*",
    "@ship-it-ui/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-links": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "remark-gfm": "^4.0.0",
    "storybook": "^10.3.6",
    "typescript": "^5.6.3",
    "vite": "^6.4.2"
  }
}
