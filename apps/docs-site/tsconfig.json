{
  "extends": "@ship-it-ui/tsconfig/react-app.json",
  "compilerOptions": {
    "tsBuildInfoFile": ".turbo/tsconfig.tsbuildinfo",
    "noEmit": true,
    "incremental": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    },
    "jsx": "preserve"
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", ".generated/**/*.ts", ".generated/**/*.json"],
  "exclude": ["node_modules", ".next", "out"],
  "references": [
    {
      "path": "../../packages/ui"
    },
    {
      "path": "../../packages/tokens"
    },
    {
      "path": "../../packages/icons"
    },
    {
      "path": "../../packages/shipit"
    }
  ]
}
