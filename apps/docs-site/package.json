{
  "name": "docs-site",
  "version": "0.0.0",
  "private": true,
  "description": "Ship-It Design System documentation site (Next.js 16, MDX, static export).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "generate": "node --experimental-strip-types scripts/build-examples-registry.ts && node --experimental-strip-types scripts/build-docgen.ts && node --experimental-strip-types scripts/build-search-index.ts",
    "predev": "pnpm run generate",
    "dev": "next dev",
    "prebuild": "pnpm run generate",
    "build": "next build",
    "start": "next start",
    "prelint": "pnpm run generate",
    "lint": "eslint app components lib mdx-components.tsx",
    "lint:fix": "eslint app components lib mdx-components.tsx --fix",
    "pretypecheck": "pnpm run generate",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next out .turbo .generated"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^16.2.10",
    "@ship-it-ui/cytoscape": "workspace:*",
    "@ship-it-ui/graph-editor": "workspace:*",
    "@ship-it-ui/icons": "workspace:*",
    "@ship-it-ui/map": "workspace:^",
    "@ship-it-ui/shipit": "workspace:*",
    "@ship-it-ui/tokens": "workspace:*",
    "@ship-it-ui/ui": "workspace:*",
    "cytoscape": "^3.33.4",
    "flexsearch": "^0.7.43",
    "github-slugger": "^2.0.0",
    "maplibre-gl": "^5.24.0",
    "mdast-util-to-string": "^4.0.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.4",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "shiki": "^1.24.4",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@ship-it-ui/eslint-config": "workspace:*",
    "@ship-it-ui/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "react-docgen-typescript": "^2.2.2",
    "tailwindcss": "4.0.0-beta.3",
    "ts-morph": "^28.0.0",
    "typescript": "^5.6.3"
  }
}
